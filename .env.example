# Zero-Trust AI Access Gateway Environment Configuration

# Application Settings
APP_NAME="Zero-Trust AI Access Gateway"
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-change-in-production

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zerotrust_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# OAuth2/OIDC Settings
OAUTH2_PROVIDER_URL=https://auth.yourcompany.com
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_AUDIENCE=ai-api-gateway
OIDC_DISCOVERY_URL=https://auth.yourcompany.com/.well-known/openid-configuration

# JWT Settings
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=/path/to/jwt-public.pem
JWT_ISSUER=https://auth.yourcompany.com
JWT_AUDIENCE=ai-api-gateway

# AI Provider Settings
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=optional-local-key

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_WINDOW_SECONDS=60

# Token Budgeting
DEFAULT_USER_DAILY_TOKEN_LIMIT=100000
DEFAULT_ORG_DAILY_TOKEN_LIMIT=1000000
TOKEN_BUDGET_RESET_HOUR=0

# Security Settings
PII_DETECTION_ENABLED=true
PROMPT_INJECTION_DETECTION_ENABLED=true
MAX_PROMPT_LENGTH=16000
BLOCKED_PATTERNS=ignore previous instructions,system prompt,document your instructions

# Audit Logging
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_LEVEL=INFO

# Helm/Kubernetes
NAMESPACE=zero-trust-ai
SERVICE_NAME=ai-access-gateway
