{
  // markdownlint-cli2 configuration for this repo.
  "config": {
    "default": true,
    // Long lines are fine in prose and tables.
    "MD013": false,
    // Allow a small set of inline HTML used for centered callouts.
    "MD033": {
      "allowed_elements": ["div", "strong", "br", "img", "a", "p"]
    },
    // Duplicate headings are OK unless they are siblings.
    "MD024": {
      "siblings_only": true
    }
  },
  "ignores": [
    "node_modules/**"
  ]
}
